@@ -0,0 +1,17 @@
+{
+  "_comment": "XD-4 aggregated a11y baseline. Per-route baselines (chat.json/home.json/login.json) under tests/TravelAssistant.E2E.Tests/a11y-baselines/ are the authoritative per-screen allowlists; this file mirrors the union for tooling that expects a single artifact path (e.g. PR comment bot, XD review). Refresh by running E2E_A11Y_UPDATE_BASELINE=1 npx playwright test --grep @a11y then regenerating this file via scripts/a11y/sync-baseline.mjs.",
+  "schema_version": 1,
+  "wcag_tags": ["wcag2a", "wcag2aa", "wcag21a", "wcag21aa"],
+  "routes": {
+    "/": { "allowed": [], "states_covered": ["default"] },
+    "/chat": { "allowed": [], "states_covered": ["empty", "streaming", "pending-patch", "error", "post-cancel", "loaded"] },
+    "/login": { "allowed": [], "states_covered": ["default", "error", "rate-limited"] }
+  },
+  "screen_state_matrix_source": "docs/design/ia.md#2-screen-coverage-matrix",
+  "non_axe_checks": [
+    "keyboard-only navigation (Tab/Shift+Tab/Esc/Enter)",
+    "screen-reader landmark hierarchy",
+    "prefers-reduced-motion honored for streaming token animation",
+    "color contrast in dark mode"
+  ]
+}
diff --git a/tests/llm-eval/goldens/G-004-interrupt-mid-stream.json b/tests/llm-eval/goldens/G-004-interrupt-mid-stream.json
new file mode 100644
index 0000000..f87689f
--- /dev/null
+++ b/tests/llm-eval/goldens/G-004-interrupt-mid-stream.json
@@ -0,0 +1,19 @@
+{
+  "id": "G-004",
+  "tags": ["streaming", "cancel", "rollback", "xd-2-s8"],
+  "description": "XD-2 §8 scenario 1: user hits Esc mid-stream. Client emits turn.cancel; server stops token emission; any 'pending' itinerary patches issued during this turn must be rolled back. Assistant's final visible state should match the 'Stopped' copy template.",
+  "messages": [
+    { "role": "user", "content": "Plan me a 5-day Tokyo trip in October for two travelers, hotel near Shinjuku, business class flights from SFO." },
+    { "role": "user", "content": "__SIMULATE_CANCEL__" }
+  ],
+  "must_include": ["Stopped"],
+  "must_not_include": ["totalCost", "flightNumber", "Grounded"],
+  "expected_provider_calls": { "flights": 0, "hotels": 0 },
+  "expected_status": "Pending",
+  "min_sources": 0,
+  "lifecycle_assertions": {
+    "events_emitted_subset": ["turn.start", "token", "turn.cancel"],
+    "events_forbidden": ["turn.end:success"],
+    "pending_patches_rolled_back": true
+  }
+}
diff --git a/tests/llm-eval/goldens/G-005-retry-after-error.json b/tests/llm-eval/goldens/G-005-retry-after-error.json
