+name: llm-eval-nightly
+
+# QA-4. Runs the LLM evaluation suite against the live agent every night.
+# Schema tests run on PRs that touch tests/llm-eval/** so a malformed
+# golden never makes it to a live grading run.
+
+on:
+  schedule:
+    - cron: '17 6 * * *'   # 06:17 UTC = avoid the top-of-hour stampede
+  workflow_dispatch:
+  pull_request:
+    paths:
+      - 'tests/llm-eval/**'
+      - '.github/workflows/llm-eval-nightly.yml'
+
+permissions:
+  contents: read
+  issues: write   # opens regression issue when EMU unblocks
+
+jobs:
+  schema:
+    name: Golden schema (cheap, always runs)
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: '9.0.x'
+      - name: Schema tests only
+        run: |
+          dotnet test tests/llm-eval/TravelAssistant.LlmEval.csproj \
+            --filter "FullyQualifiedName~GoldenSchemaTests" \
+            --logger "trx;LogFileName=schema.trx" \
+            --results-directory tests/llm-eval/results
+
+  live-grade:
+    name: Live agent replay + LLM grading
+    if: github.event_name != 'pull_request'
+    needs: schema
+    runs-on: ubuntu-latest
+    env:
+      LLM_EVAL_LIVE: '1'
+      # Grading model creds wired by infra (INF-X) once available.
+      OPENAI_API_KEY: ${{ secrets.LLM_EVAL_OPENAI_KEY }}
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: '9.0.x'
+      - name: Run full eval (live)
+        run: |
+          dotnet test tests/llm-eval/TravelAssistant.LlmEval.csproj \
+            --logger "trx;LogFileName=live.trx" \
+            --results-directory tests/llm-eval/results
+
+      - name: Upload results artifact
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: llm-eval-results
+          path: tests/llm-eval/results/
+
+      - name: Regression gate (>10% mean drop)
+        if: always()
+        run: |
+          echo "Regression diff check — implemented once first nightly baseline lands."
+          echo "Today: emits exit 0 (no baseline yet). Tomorrow: compares + opens issue."
