+name: e2e-a11y
+
+# QA-1 (smoke) + QA-3 (a11y baseline-gated). Per-PR.
+
+on:
+  pull_request:
+    paths:
+      - 'src/**'
+      - 'tests/TravelAssistant.E2E.Tests/**'
+      - '.github/workflows/e2e-a11y.yml'
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  e2e:
+    name: Playwright smoke + axe
+    runs-on: ubuntu-latest
+    defaults:
+      run:
+        working-directory: tests/TravelAssistant.E2E.Tests
+    steps:
+      - uses: actions/checkout@v4
+
+      - uses: actions/setup-node@v4
+        with:
+          node-version: '20'
+          cache: 'npm'
+          cache-dependency-path: tests/TravelAssistant.E2E.Tests/package.json
+
+      - run: npm install
+      - run: npx playwright install --with-deps chromium
+
+      # Once APP-1 lands, replace with `aspire run` / `dotnet run --project apphost`.
+      # For now the suite runs against E2E_BASE_URL provided by the workflow.
+      - name: Run smoke
+        env:
+          E2E_BASE_URL: ${{ vars.E2E_BASE_URL || 'http://localhost:5173' }}
+        run: npm run test:smoke
+
+      - name: Run a11y (baseline-gated)
+        env:
+          E2E_BASE_URL: ${{ vars.E2E_BASE_URL || 'http://localhost:5173' }}
+        run: npm run test:a11y
+
+      - name: Upload Playwright report
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: playwright-report
+          path: tests/TravelAssistant.E2E.Tests/playwright-report/
