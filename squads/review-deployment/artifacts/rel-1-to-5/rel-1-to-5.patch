+++ b/.github/workflows/ci.yml
@@ -0,0 +1,138 @@
+name: CI
+
+# REL-1: Build, test, lint, secret scan on every PR + main push.
+# This workflow is the required check that gates merges to main.
+
+on:
+  pull_request:
+    branches: [main]
+  push:
+    branches: [main]
+  workflow_dispatch:
+
+permissions:
+  contents: read
+  pull-requests: read
+  security-events: write
+
+concurrency:
+  group: ci-${{ github.workflow }}-${{ github.ref }}
+  cancel-in-progress: true
+
+env:
+  DOTNET_NOLOGO: true
+  DOTNET_CLI_TELEMETRY_OPTOUT: true
+  DOTNET_SKIP_FIRST_TIME_EXPERIENCE: true
+
+jobs:
+  build-test:
+    name: build + test (.NET)
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+
+      - name: Setup .NET
+        uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: |
+            9.0.x
+
+      - name: Cache NuGet packages
+        uses: actions/cache@v4
+        with:
+          path: ~/.nuget/packages
+          key: ${{ runner.os }}-nuget-${{ hashFiles('**/*.csproj', '**/*.slnx', '**/Directory.Packages.props') }}
+          restore-keys: |
+            ${{ runner.os }}-nuget-
+
+      - name: Restore
+        run: dotnet restore TravelAssistant.slnx
+
+      - name: Build
+        run: dotnet build TravelAssistant.slnx --configuration Release --no-restore /warnaserror
+
+      - name: Test
+        run: |
+          dotnet test TravelAssistant.slnx \
+            --configuration Release \
+            --no-build \
+            --logger "trx;LogFileName=test-results.trx" \
+            --logger "GitHubActions;summary.includePassedTests=false" \
+            --collect:"XPlat Code Coverage" \
+            --results-directory ./TestResults
+
+      - name: Upload test results
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: test-results
+          path: TestResults/**/*
+          retention-days: 7
+
+  lint-format:
+    name: lint + format
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: 9.0.x
+      - name: Verify dotnet format
+        run: dotnet format TravelAssistant.slnx --verify-no-changes --severity warn
+
+  secret-scan:
+    name: secret scan (gitleaks)
+    runs-on: ubuntu-latest
+    timeout-minutes: 5
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+      - name: Run gitleaks
+        uses: gitleaks/gitleaks-action@v2
+        env:
+          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
+          GITLEAKS_ENABLE_UPLOAD_ARTIFACT: true
+          GITLEAKS_ENABLE_SUMMARY: true
+
+  codeql:
+    name: CodeQL (C#)
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    permissions:
+      security-events: write
+      contents: read
+      actions: read
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: 9.0.x
+      - uses: github/codeql-action/init@v3
+        with:
+          languages: csharp
+          build-mode: autobuild
+      - uses: github/codeql-action/analyze@v3
+        with:
+          category: "/language:csharp"
+
+  ci-gate:
+    name: CI Gate (required)
+    needs: [build-test, lint-format, secret-scan, codeql]
+    runs-on: ubuntu-latest
+    if: always()
+    steps:
+      - name: Fail if any required job failed
+        run: |
+          if [[ "${{ needs.build-test.result }}" != "success" \
+             || "${{ needs.lint-format.result }}" != "success" \
+             || "${{ needs.secret-scan.result }}" != "success" \
+             || "${{ needs.codeql.result }}" != "success" ]]; then
+            echo "One or more required CI jobs failed."
+            exit 1
+          fi
+          echo "All required CI jobs passed."
diff --git a/.github/workflows/deploy-staging.yml b/.github/workflows/deploy-staging.yml
new file mode 100644
index 0000000..7756af8
--- /dev/null
+++ b/.github/workflows/deploy-staging.yml
@@ -0,0 +1,169 @@
+name: Deploy to Staging
+
+# REL-2: On merge to main, deploy via `azd` to the staging environment,
+# then run Playwright smoke tests. On smoke failure, roll back the
+# Container Apps revision (REL-5).
+#
+# Prerequisites (configured by azure-infrastructure-squad):
+#   - GitHub OIDC federation to Azure (no client secrets)
+#   - Repo secrets: AZURE_CLIENT_ID, AZURE_TENANT_ID, AZURE_SUBSCRIPTION_ID
+#   - Repo variables: AZURE_ENV_NAME=staging, AZURE_LOCATION
+#   - azd template wired to the Aspire AppHost
+
+on:
+  push:
+    branches: [main]
+  workflow_dispatch:
+    inputs:
+      skip_smoke:
+        description: "Skip Playwright smoke tests"
+        type: boolean
+        default: false
+
+permissions:
+  id-token: write
+  contents: read
+
+concurrency:
+  group: deploy-staging
+  cancel-in-progress: false
+
+env:
+  AZURE_ENV_NAME: ${{ vars.AZURE_ENV_NAME || 'staging' }}
+  AZURE_LOCATION: ${{ vars.AZURE_LOCATION || 'westeurope' }}
+
+jobs:
+  deploy:
+    name: azd deploy → staging
+    runs-on: ubuntu-latest
+    timeout-minutes: 30
+    environment:
+      name: staging
+      url: ${{ steps.deploy.outputs.endpoint_url }}
+    outputs:
+      previous_revision: ${{ steps.snapshot.outputs.previous_revision }}
+      endpoint_url: ${{ steps.deploy.outputs.endpoint_url }}
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Setup .NET
+        uses: actions/setup-dotnet@v4
+        with:
+          dotnet-version: 9.0.x
+
+      - name: Install azd
+        uses: Azure/setup-azd@v2
+
+      - name: Azure login (OIDC)
+        uses: azure/login@v2
+        with:
+          client-id: ${{ secrets.AZURE_CLIENT_ID }}
+          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
+          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}
+
+      - name: azd auth login (federated)
+        run: |
+          azd auth login \
+            --client-id "${{ secrets.AZURE_CLIENT_ID }}" \
+            --federated-credential-provider github \
+            --tenant-id "${{ secrets.AZURE_TENANT_ID }}"
+
+      - name: Snapshot current revision (for rollback)
+        id: snapshot
+        run: |
+          set -e
+          RG="rg-travel-assistant-${AZURE_ENV_NAME}"
+          APP_NAME=$(az containerapp list -g "$RG" --query "[?contains(name,'api')].name | [0]" -o tsv || true)
+          if [ -n "$APP_NAME" ]; then
+            REV=$(az containerapp revision list -g "$RG" -n "$APP_NAME" \
+              --query "[?properties.active].name | [0]" -o tsv)
+            echo "previous_revision=${APP_NAME}::${REV}" >> "$GITHUB_OUTPUT"
+            echo "Captured previous revision: ${APP_NAME}::${REV}"
+          else
+            echo "previous_revision=" >> "$GITHUB_OUTPUT"
+            echo "No existing Container App found — first deploy."
+          fi
+
+      - name: azd deploy
+        id: deploy
+        run: |
+          set -e
+          azd env select "$AZURE_ENV_NAME" 2>/dev/null || azd env new "$AZURE_ENV_NAME" --location "$AZURE_LOCATION" --subscription "${{ secrets.AZURE_SUBSCRIPTION_ID }}"
+          azd deploy --no-prompt
+          URL=$(azd env get-values | grep -E '^SERVICE_API_URI|^API_URL' | head -1 | cut -d'=' -f2- | tr -d '"' || true)
+          echo "endpoint_url=${URL:-https://staging.travel-assistant.invalid}" >> "$GITHUB_OUTPUT"
+
+  smoke:
+    name: Playwright smoke (staging)
+    needs: deploy
+    if: ${{ inputs.skip_smoke != true }}
+    runs-on: ubuntu-latest
+    timeout-minutes: 15
+    outputs:
+      result: ${{ steps.run.outcome }}
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-node@v4
+        with:
+          node-version: "20"
+
+      - name: Install Playwright
+        working-directory: tests/smoke
+        run: |
+          if [ -f package.json ]; then
+            npm ci
+            npx playwright install --with-deps chromium
+          else
+            echo "::warning::tests/smoke not present — skipping smoke run."
+            exit 0
+          fi
+
+      - name: Run smoke
+        id: run
+        working-directory: tests/smoke
+        env:
+          STAGING_URL: ${{ needs.deploy.outputs.endpoint_url }}
+        run: |
+          if [ -f package.json ]; then
+            npx playwright test --reporter=line
+          fi
+
+      - name: Upload Playwright report
+        if: always()
+        uses: actions/upload-artifact@v4
+        with:
+          name: playwright-report
+          path: tests/smoke/playwright-report
+          if-no-files-found: ignore
+          retention-days: 7
+
+  rollback:
+    name: Rollback on smoke failure
+    needs: [deploy, smoke]
+    if: failure() && needs.deploy.outputs.previous_revision != ''
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    steps:
+      - name: Azure login (OIDC)
+        uses: azure/login@v2
+        with:
+          client-id: ${{ secrets.AZURE_CLIENT_ID }}
+          tenant-id: ${{ secrets.AZURE_TENANT_ID }}
+          subscription-id: ${{ secrets.AZURE_SUBSCRIPTION_ID }}
+
+      - name: Pin traffic back to previous revision
+        run: |
+          set -e
+          RG="rg-travel-assistant-${AZURE_ENV_NAME}"
+          PREV="${{ needs.deploy.outputs.previous_revision }}"
+          APP_NAME="${PREV%%::*}"
+          REV_NAME="${PREV##*::}"
+          echo "Rolling back $APP_NAME → $REV_NAME"
+          az containerapp ingress traffic set \
+            -g "$RG" -n "$APP_NAME" \
+            --revision-weight "${REV_NAME}=100"
+          az containerapp revision deactivate \
+            -g "$RG" -n "$APP_NAME" --revision "$(az containerapp revision list -g "$RG" -n "$APP_NAME" --query "[?name!='$REV_NAME' && properties.active].name | [0]" -o tsv)" || true
+
+      - name: Notify rollback
+        run: echo "::error::Staging deploy rolled back to ${{ needs.deploy.outputs.previous_revision }}. See docs/runbooks/rollback.md."
