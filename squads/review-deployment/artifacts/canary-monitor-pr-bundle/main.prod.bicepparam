using './main.bicep'

param environment = 'prod'
param namePrefix = 'travel-assistant'
param containerAppsEnvironmentId = '/subscriptions/{sub}/resourceGroups/travel-assistant-prod-rg/providers/Microsoft.App/managedEnvironments/travel-assistant-cae-prod'
param canaryKeyVaultId = '/subscriptions/{sub}/resourceGroups/travel-assistant-prod-rg/providers/Microsoft.KeyVault/vaults/travel-assistant-kv-canary-prod'
param canaryKeyVaultUri = 'https://travel-assistant-kv-canary-prod.vault.azure.net/'
param applicationInsightsId = '/subscriptions/{sub}/resourceGroups/travel-assistant-prod-rg/providers/Microsoft.Insights/components/travel-assistant-ai-prod'
param applicationInsightsConnectionString = '__SET_VIA_ENV_OR_KEYVAULT__'
param logAnalyticsWorkspaceId = '/subscriptions/{sub}/resourceGroups/travel-assistant-prod-rg/providers/Microsoft.OperationalInsights/workspaces/travel-assistant-law-prod'
param checkoutApiBaseUrl = 'https://api.travel-assistant.example.com'
param canaryRunnerImage = 'travelassistantacr.azurecr.io/canary-runner:v1.0.0'
param pagerDutyP1ActionGroupId = '/subscriptions/{sub}/resourceGroups/travel-assistant-shared-rg/providers/Microsoft.Insights/actionGroups/pd-p1'
param pagerDutyP2ActionGroupId = '/subscriptions/{sub}/resourceGroups/travel-assistant-shared-rg/providers/Microsoft.Insights/actionGroups/pd-p2'
param pagerDutyP3ActionGroupId = '/subscriptions/{sub}/resourceGroups/travel-assistant-shared-rg/providers/Microsoft.Insights/actionGroups/pd-p3'
