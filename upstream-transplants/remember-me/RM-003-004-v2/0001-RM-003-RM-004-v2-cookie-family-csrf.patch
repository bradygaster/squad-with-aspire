-
-export interface StoredRefreshToken {
-  token: string;
-  expiresAt: number; // epoch ms
-  rememberMe: boolean;
-}
-
-export function persistRefreshToken(token: StoredRefreshToken): void {
-  if (typeof window === 'undefined') return;
